<footer>
    <a href="https://x.com/keejkrej">X</a>
    <a href="https://github.com/keejkrej">GitHub</a>
</footer>

<style>
    main {
        max-width: 640px;
        margin: 0 auto;
        padding: 2rem;
        line-height: 1.6;
    }
    h1 {
        margin-top: 0;
    }
    ul {
        padding-left: 1.25rem;
    }
    footer {
        max-width: 640px;
        margin: 0 auto;
        padding: 0 2rem 2rem;
