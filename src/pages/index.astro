---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main>
        <section class="section">
            <h2>Who I Am</h2>
            <p>
                From China, born in 2000. Currently researching targeted LNP
                gene delivery. Grew up in Shanghai through high school, then
                stayed in Munich for bachelor, master, and PhD.
            </p>
        </section>

        <section class="section">
            <h2>What I Do</h2>
            <p>
                Vibe coding. I reinvent the wheels I hate to use. Here are some
                projects I like:
            </p>

            <div class="project-group">
                <p>Scientific tooling:</p>
                <ul class="project-list">
                    <li>
                        <a href="https://github.com/keejkrej/nd2-rs">nd2-rs</a>
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/czi-rs">czi-rs</a>
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/bioformats-zig"
                            >bioformats-zig</a
                        >
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/mdat">mdat</a>
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/mtools">mtools</a>
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/mplot-rs"
                            >mplot-rs</a
                        >
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/mlab-rs">mlab-rs</a
                        >
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/nd2-viewer"
                            >nd2-viewer</a
                        >
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/excalidraw-cli"
                            >excalidraw-cli</a
                        >
                    </li>
                </ul>
            </div>

            <div class="project-group">
                <p>Agents:</p>
                <ul class="project-list">
                    <li>
                        <a href="https://github.com/keejkrej/reflect">reflect</a
                        >
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/agent-plot"
                            >agent-plot</a
                        >
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/100PUA">100PUA</a>
                    </li>
                    <li>
                        <a href="https://github.com/keejkrej/implAgent4Me"
                            >implAgent4Me</a
                        >
                    </li>
                </ul>
            </div>
        </section>

        <section class="section">
            <h2>What I Believe</h2>
            <p>
                Humans are the interface of AI to the physical world. Aim to
                clone myself digitally.
            </p>
        </section>

        <section class="section">
            <h2>Who I Like</h2>
            <p>No bullshit.</p>
            <p>Criticize me but grounded.</p>
            <p>Open source minded.</p>
        </section>
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .section h2 {
        font-size: 1.25rem;
        margin: 0 0 0.75rem;
        color: var(--accent);
    }

    .section p {
        margin: 0 0 0.75rem;
    }

    .section p:last-child {
        margin-bottom: 0;
    }

    .section p {
        margin: 0 0 0.75rem;
    }

    .section p:last-child {
        margin-bottom: 0;
    }

    .project-group {
        margin-top: 1.25rem;
        padding: 1.25rem;
        background: var(--card-bg);
        border: 1px solid var(--border);
        border-radius: 0.75rem;
    }

    .project-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 0.35rem 1rem;
    }

    .project-list li {
        display: block;
        margin: 0;
    }

    .project-list a {
        font-family: var(--font-mono);
        font-size: 0.95rem;
    }
</style>
