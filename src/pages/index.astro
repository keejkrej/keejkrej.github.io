---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <main>
        <section class="hero">
            <p class="eyebrow">PhD student & open-source toolmaker</p>
            <h1>Tianyi Cao</h1>
            <p class="tagline">
                From Shanghai, based in Munich. I build small, sharp tools for
                microscopy and agents. Currently researching targeted LNP gene
                delivery at LMU.
            </p>
        </section>

        <section class="section">
            <span class="section__label">Projects</span>
            <p class="section__lead">
                I reinvent the wheels I hate to use. Most of them live on
                GitHub.
            </p>

            <div class="project-grid">
                <a class="project" href="https://github.com/keejkrej/nd2-rs">
                    <span class="project__name">nd2-rs</span>
                    <span class="project__desc">Nikon ND2 reader in Rust</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/czi-rs">
                    <span class="project__name">czi-rs</span>
                    <span class="project__desc">Zeiss CZI decoder</span>
                </a>
                <a
                    class="project"
                    href="https://github.com/keejkrej/bioformats-zig"
                >
                    <span class="project__name">bioformats-zig</span>
                    <span class="project__desc">Bioformats in Zig</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/mdat">
                    <span class="project__name">mdat</span>
                    <span class="project__desc">Metadata helpers</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/mtools">
                    <span class="project__name">mtools</span>
                    <span class="project__desc">Microscopy utilities</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/mplot-rs">
                    <span class="project__name">mplot-rs</span>
                    <span class="project__desc">Plotting for science</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/mlab-rs">
                    <span class="project__name">mlab-rs</span>
                    <span class="project__desc">Lab notebook toolkit</span>
                </a>
                <a
                    class="project"
                    href="https://github.com/keejkrej/nd2-viewer"
                >
                    <span class="project__name">nd2-viewer</span>
                    <span class="project__desc">Browser ND2 viewer</span>
                </a>
                <a
                    class="project"
                    href="https://github.com/keejkrej/excalidraw-cli"
                >
                    <span class="project__name">excalidraw-cli</span>
                    <span class="project__desc">CLI for Excalidraw</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/reflect">
                    <span class="project__name">reflect</span>
                    <span class="project__desc">Agent self-reflection</span>
                </a>
                <a
                    class="project"
                    href="https://github.com/keejkrej/agent-plot"
                >
                    <span class="project__name">agent-plot</span>
                    <span class="project__desc">Agent-driven plotting</span>
                </a>
                <a class="project" href="https://github.com/keejkrej/100PUA">
                    <span class="project__name">100PUA</span>
                    <span class="project__desc">Prompt archive</span>
                </a>
                <a
                    class="project"
                    href="https://github.com/keejkrej/implAgent4Me"
                >
                    <span class="project__name">implAgent4Me</span>
                    <span class="project__desc">Personal agent</span>
                </a>
            </div>
        </section>

        <section class="section section--belief">
            <span class="section__label">Belief</span>
            <p>
                Humans are the interface of AI to the physical world. My goal is
                to clone myself digitally.
            </p>
        </section>

        <section class="section section--values">
            <span class="section__label">Values</span>
            <ul class="value-list">
                <li>No bullshit.</li>
                <li>Criticize me, but be grounded.</li>
                <li>Open source minded.</li>
            </ul>
        </section>
    </main>
</Layout>

<style>
    main {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }

    .hero {
        max-width: 620px;
    }

    .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--text-muted);
        margin: 0 0 1rem;
    }

    h1 {
        font-size: clamp(3rem, 10vw, 5rem);
        font-weight: 300;
        margin: 0 0 1.25rem;
    }

    .tagline {
        font-size: 1.15rem;
        color: var(--text-muted);
        margin: 0;
    }

    .section {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .section__label {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
    }

    .section__lead {
        font-size: 1.05rem;
        color: var(--text-muted);
        margin: 0;
        max-width: 540px;
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1px;
        background: var(--rule);
        border: 1px solid var(--rule);
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .project {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1rem 1.1rem;
        background: var(--bg);
        border-bottom: 0;
        transition: background 0.15s ease;
    }

    .project:hover {
        background: var(--bg-soft);
    }

    .project__name {
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--text);
    }

    .project__desc {
        font-size: 0.9rem;
        color: var(--text-muted);
    }

    .section--belief p,
    .section--values ul {
        font-size: 1.15rem;
        margin: 0;
        max-width: 620px;
    }

    .value-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .value-list li::before {
        content: "—";
        color: var(--accent);
        margin-right: 0.65rem;
    }
</style>
